## 4. EXECUÇÃO DE COMANDOS (exec.c)

### 4.1 Comandos Internos

#### CD (Change Directory)
```c
if (strcmp(prog, "cd") == 0) {
    char *path = cmd.cmd1->args[1];
    if (path == NULL) {
        printf("cd: caminho ausente\n");
        return;
    }
    if (cmd.cmd1->args[2] != NULL) {
        printf("cd: muitos argumentos\n");
        return;
    }
    if (chdir(path) != 0) {
        perror("cd");
    }
    return;
}
```
**Características:**
- Muda diretório corrente da shell
- Requer exatamente 1 argumento
- Afeta próximos comandos que usarem caminhos relativos

#### WAIT
```c
if (strcmp(prog, "wait") == 0) {
    if (cmd.cmd1->args[1] != NULL) {
        printf("wait: não aceita argumentos\n");
        return;
    }
    reap_zombies(lasy);
    return;
}
```
**reap_zombies():**
```c
static void reap_zombies(IshState *lasy) {
    if (lasy->zombie_count == 0) {
        printf("Não há processos zumbis.\n");
        return;
    }
    for (int i = 0; i < lasy->zombie_count; i++) {
        report_child_status(lasy->zombie_pids[i], 
                           lasy->zombie_status[i]);
        remove_child(lasy, lasy->zombie_pids[i]);
    }
    lasy->zombie_count = 0;
}
```
**report_child_status():**
```c
static void report_child_status(pid_t pid, int status) {
    if (WIFEXITED(status)) {
        printf("Processo %d terminou com status %d\n", 
               pid, WEXITSTATUS(status));
    }
    else if (WIFSIGNALED(status)) {
        printf("Processo %d terminou por sinal %d\n", 
               pid, WTERMSIG(status));
    }
    else if (WIFSTOPPED(status)) {
        printf("Processo %d parou por sinal %d\n", 
               pid, WSTOPSIG(status));
    }
    else {
        printf("Processo %d terminou por causa desconhecida\n", pid);
    }
}
```

#### EXIT
```c
if (strcmp(prog, "exit") == 0) {
    if (cmd.cmd1->args[1] != NULL) {
        printf("exit: não aceita argumentos\n");
        return;
    }
    exit_shell(lasy);
    return;
}
```
**exit_shell():**
```c
static void exit_shell(IshState *lasy) {
    // 1. Coleta grupos únicos
    pid_t groups[MAX_CHILDREN];
    int group_count = 0;
    
    for (int i = 0; i < lasy->child_count; i++) {
        pid_t pgid = getpgid(lasy->children[i]);
        if (pgid < 0) {
            kill(lasy->children[i], SIGTERM);
            continue;
        }
        // Adiciona grupo se ainda não existe na lista
        int exists = 0;
        for (int g = 0; g < group_count; g++) {
            if (groups[g] == pgid) {
                exists = 1;
                break;
            }
        }
        if (!exists) {
            groups[group_count++] = pgid;
            kill(-pgid, SIGTERM);  // Mata o grupo inteiro
        }
    }
    
    // 2. Aguarda todos os filhos
    int status;
    pid_t pid;
    while ((pid = waitpid(-1, &status, 0)) > 0) {
        report_child_status(pid, status);
    }
    
    // 3. Finaliza
    exit(0);
}
```

### 4.2 Comandos Externos

#### fork_exec() - Criação de Processos
```c
static pid_t fork_exec(Command *cmd, pid_t group_id, 
                       int in_fd, int out_fd, int close_fd) {
    pid_t pid = fork();
    
    if (pid == 0) {  // PROCESSO FILHO
        // 1. Configura grupo de processos
        if (group_id < 0) {
            setpgid(0, 0);      // Cria novo grupo (líder)
        } else {
            setpgid(0, group_id); // Entra no grupo existente
        }
        
        // 2. Ignora SIGINT (Ctrl-C não mata filhos)
        signal(SIGINT, SIG_IGN);
        
        // 3. Fecha fd que não será usado
        if (close_fd >= 0) {
            close(close_fd);
        }
        
        // 4. Redireciona entrada se necessário
        if (in_fd >= 0) {
            dup2(in_fd, STDIN_FILENO);
        }
        
        // 5. Redireciona saída se necessário
        if (out_fd >= 0) {
            dup2(out_fd, STDOUT_FILENO);
        }
        
        // 6. Fecha fds após redirecionamento
        if (in_fd > STDERR_FILENO) close(in_fd);
        if (out_fd > STDERR_FILENO) close(out_fd);
        
        // 7. Executa o programa
        execvp(cmd->name, cmd->args);
        perror("execvp");
        _exit(127);
    }
    
    return pid;  // PROCESSO PAI retorna PID do filho
}
```

#### Execução com Pipe
```c
if (cmd.has_pipe == 1) {
    // 1. Cria o pipe
    int fd[2];
    if (pipe(fd) != 0) {
        perror("pipe");
        return;
    }
    // fd[0] = leitura, fd[1] = escrita
    
    // 2. Cria primeiro processo (escreve no pipe)
    pid_t pid1 = fork_exec(cmd.cmd1, *group_id, -1, fd[1], fd[0]);
    //                      entrada: stdin normal
    //                      saída: fd[1] (pipe)
    //                      fecha: fd[0] (não usa)
    
    if (pid1 < 0) {
        perror("fork");
        close(fd[0]);
        close(fd[1]);
        return;
    }
    
    // Define grupo (primeiro processo é o líder)
    if (*group_id < 0) {
        *group_id = pid1;
    }
    
    // 3. Cria segundo processo (lê do pipe)
    pid_t pid2 = fork_exec(cmd.cmd2, *group_id, fd[0], -1, fd[1]);
    //                      entrada: fd[0] (pipe)
    //                      saída: stdout normal
    //                      fecha: fd[1] (não usa)
    
    if (pid2 < 0) {
        perror("fork");
        close(fd[0]);
        close(fd[1]);
        return;
    }
    
    // 4. PAI fecha ambos os fds
    close(fd[0]);
    close(fd[1]);
    
    // 5. Registra filhos
    add_child(lasy, pid1);
    add_child(lasy, pid2);
}
```

**Diagrama do Pipe:**
```
         PAI (shell)
            |
    +-------+-------+
    |               |
  PID1            PID2
ls -l           grep txt
    |               |
stdout→[fd[1]] [fd[0]]→stdin
        ↓       ↑
        +-------+
          PIPE
```

#### Execução Simples (sem pipe)
```c
if (cmd.has_pipe == 0) {
    pid_t pid = fork_exec(cmd.cmd1, *group_id, -1, -1, -1);
    //                    entrada: stdin normal
    //                    saída: stdout normal
    //                    não fecha nada extra
    
    if (pid < 0) {
        perror("fork");
        return;
    }
    
    if (*group_id < 0) {
        *group_id = pid;
    }
    
    add_child(lasy, pid);
}
```

### 4.3 execute_buffer() - Execução do Buffer

```c
void execute_buffer(IshState *lasy) {
    pid_t group_id = -1;  // Começa sem grupo
    
    for (int i = 0; i < lasy->count; i++) {
        execute_command(lasy->buffer[i], lasy, &group_id);
        // group_id é passado por referência
        // Primeiro externo cria o grupo
        // Demais entram no mesmo grupo
    }
}
```

**Exemplo de execução:**
```
Buffer: ["ls", "cd ..", "ps aux"]
group_id inicial: -1

1. execute_command("ls")
   - Externo, group_id == -1
   - fork_exec cria processo PID 1234
   - setpgid(0, 0) → cria grupo 1234
   - group_id = 1234

2. execute_command("cd ..")
   - Interno
   - chdir("..") no processo pai
   - group_id continua 1234

3. execute_command("ps aux")
   - Externo, group_id == 1234
   - fork_exec cria processo PID 1235
   - setpgid(0, 1234) → entra no grupo 1234
   - group_id continua 1234

Resultado: ls e ps estão no grupo 1234
```

